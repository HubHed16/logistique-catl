# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env*.example

# yarn.lock (le .gitignore racine ignore *.lock, on le ré-inclut ici)
!yarn.lock

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# playwright
/test-results/
/playwright-report/
/playwright/.cache/

# package manager (le projet utilise yarn — on ne commite pas le lockfile npm)
package-lock.json

# Claude Code preview local (launch.json, etc.)
/.claude/

# types générés par next typegen (régénérés au build)
/.next-routes-types/
