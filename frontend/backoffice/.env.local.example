# Base URL du client API côté browser. Par défaut `/api/tour` → passe par
# les Route Handlers de Next (src/app/api/tour/[...path]/route.ts) qui
# proxyent vers `TOUR_API_PROXY_TARGET` (ci-dessous). Laisse cette variable
# vide/non définie pour éviter les soucis de CORS.
# NEXT_PUBLIC_API_BASE_URL=/api/tour

# Cible du proxy serveur-side pour `/api/tour/*`. En dev (yarn dev), pas
# besoin de la définir : fallback `http://localhost:8080` (tour-api lancé
# par `docker compose up -d tour-api`).
# TOUR_API_PROXY_TARGET=http://localhost:8080

# Idem pour le WMS — proxy `/api/wms/*` (fallback http://localhost:8081).
# WMS_API_PROXY_TARGET=http://localhost:8081

# Mock API : intercepte les fetch openapi-fetch et répond depuis
# localStorage, pratique pour les endpoints pas encore exposés par le back.
NEXT_PUBLIC_USE_MOCKS=true
